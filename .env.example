# ─────────────────────────────────────────────────────────────
# Aswaq Enterprise – Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# ── Server ──────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
ALLOW_DEMO_SEEDING=false
VITE_API_URL=https://aswaq22.com
CORS_ORIGIN=https://aswaq22.com,https://admin.aswaq22.com,https://api.aswaq22.com

# ── Database (PostgreSQL) ────────────────────────────────────
DATABASE_URL=postgresql://aswaq:your_password@localhost:5432/aswaqdb
POSTGRES_USER=aswaq
POSTGRES_PASSWORD=your_password
POSTGRES_DB=aswaqdb
POSTGRES_PORT=5432

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=                 # Leave empty for no auth (dev)
REDIS_PORT=6379

# ── Meilisearch ──────────────────────────────────────────────
MEILI_HOST=http://localhost:7700
MEILI_API_KEY=your_meilisearch_master_key
MEILI_MASTER_KEY=your_meilisearch_master_key
MEILI_PORT=7700

# ── Auth & Security ──────────────────────────────────────────
JWT_SECRET=minimum-32-character-random-string-here!!
PEPPER_SECRET=another-random-string-for-password-hashing
ACCESS_TOKEN_EXPIRES=15m
REFRESH_TOKEN_EXPIRES=7d

# ── OAuth2 (optional) ────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://aswaq22.com/api/v1/auth/oauth2/callback
WEB_RETURN_URL=https://aswaq22.com/
ADMIN_URL=https://admin.aswaq22.com/
MOBILE_DEEPLINK=com.aswaq.enterprise://oauth
FRONTEND_URL=https://aswaq22.com
DOMAIN=aswaq22.com

APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=

# ── Storage (Cloudflare R2 or AWS S3) ────────────────────────
STORAGE_PROVIDER=local          # local | r2 | s3
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=aswaq-uploads
R2_PUBLIC_URL=https://cdn.aswaq.com

# ── AI / Gemini ──────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key

# ── Notifications ────────────────────────────────────────────
FCM_SERVER_KEY=                 # Firebase Cloud Messaging
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
OTP_PROVIDER=firebase           # twilio | firebase
VITE_OTP_PROVIDER=firebase      # twilio | firebase

# ── Outbox Worker ────────────────────────────────────────────
OUTBOX_POLL_MS=5000             # Poll interval (ms)
OUTBOX_BATCH_SIZE=50            # Events per batch
OUTBOX_MAX_RETRIES=5            # Max retry attempts before DLQ

# ── Observability ────────────────────────────────────────────
SENTRY_DSN=                     # Sentry error tracking DSN
OTEL_EXPORTER_OTLP_ENDPOINT=   # OpenTelemetry collector URL

# ── E2E Tests ────────────────────────────────────────────────
E2E_BASE_URL=http://localhost:3000
E2E_TEST_EMAIL=test@aswaq.com
E2E_TEST_PASSWORD=TestPassword123!

# Frontend build-time env
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
