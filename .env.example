# .env.example — Aswaq 22 Environment Variables Template
# Copy this file to .env and fill in the values
# NEVER commit the real .env file to git

# ══════════════════════════════════════════════════════════════
# DATABASE
# ══════════════════════════════════════════════════════════════
DATABASE_URL="postgresql://user:password@host:5432/dbname?pgbouncer=true"
DIRECT_URL="postgresql://user:password@host:5432/dbname"

# ══════════════════════════════════════════════════════════════
# SECURITY — REQUIRED
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ══════════════════════════════════════════════════════════════
JWT_SECRET="generate-a-64-char-random-hex-string"
JWT_REFRESH_SECRET="generate-a-different-64-char-random-hex-string"
PEPPER_SECRET="generate-another-64-char-random-hex-string"

# ══════════════════════════════════════════════════════════════
# APPLICATION
# ══════════════════════════════════════════════════════════════
PORT=3002
NODE_ENV=development
FRONTEND_URL="http://localhost:5174"
CORS_ORIGIN="http://localhost:5174,http://localhost:5173"

# ══════════════════════════════════════════════════════════════
# REDIS
# ══════════════════════════════════════════════════════════════
REDIS_HOST="localhost"
REDIS_PORT=6379
# REDIS_PASSWORD=""  # Uncomment if Redis requires a password
# REDIS_URL=""       # Or use a full Redis URL

# ══════════════════════════════════════════════════════════════
# MEILISEARCH
# ══════════════════════════════════════════════════════════════
MEILI_HOST="http://localhost:7700"
MEILI_API_KEY="your-meilisearch-api-key"
MEILI_MASTER_KEY="your-meilisearch-master-key"

# ══════════════════════════════════════════════════════════════
# GOOGLE OAUTH2
# ══════════════════════════════════════════════════════════════
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_REDIRECT_URI="http://localhost:3002/api/v1/auth/oauth2/callback"
VITE_GOOGLE_MAPS_API_KEY="your-google-maps-api-key"

# ══════════════════════════════════════════════════════════════
# FIREBASE
# ══════════════════════════════════════════════════════════════
FIREBASE_SERVICE_ACCOUNT='{"type":"service_account","project_id":"your-project",...}'
FIREBASE_WEB_API_KEY="your-firebase-web-api-key"
VITE_FIREBASE_API_KEY="your-firebase-api-key"
VITE_FIREBASE_PROJECT_ID="your-firebase-project-id"
VITE_FIREBASE_AUTH_DOMAIN="your-project.firebaseapp.com"

# ══════════════════════════════════════════════════════════════
# OTP / SMS
# ══════════════════════════════════════════════════════════════
OTP_PROVIDER=twilio
VITE_OTP_PROVIDER=twilio
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# ══════════════════════════════════════════════════════════════
# RECAPTCHA
# ══════════════════════════════════════════════════════════════
RECAPTCHA_SITE_KEY="your-recaptcha-site-key"
RECAPTCHA_SECRET_KEY="your-recaptcha-secret-key"
VITE_RECAPTCHA_SITE_KEY="your-recaptcha-site-key"

# ══════════════════════════════════════════════════════════════
# AI / GEMINI
# ══════════════════════════════════════════════════════════════
GEMINI_API_KEY="your-gemini-api-key"

# ══════════════════════════════════════════════════════════════
# OBSERVABILITY — METRICS
# At least one of these should be set in production
# ══════════════════════════════════════════════════════════════
# METRICS_TOKEN="generate-a-secure-random-token"
# METRICS_ALLOWED_IPS="prometheus,172.20.0.0/16"

# ══════════════════════════════════════════════════════════════
# FEATURE FLAGS
# ══════════════════════════════════════════════════════════════
VITE_MAINTENANCE_MODE=false
VITE_DEV_MODE=false
