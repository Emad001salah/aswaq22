{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "vite": "vite",
    "dev:full": "concurrently \"npm run dev\" \"npm run vite\"",
    "dev": "tsx server.ts",
    "build": "cross-env NODE_OPTIONS=--max-old-space-size=4096 vite build",
    "analyze": "cross-env ANALYZE=true NODE_OPTIONS=--max-old-space-size=4096 vite build",
    "start": "tsx server.ts",
    "test": "cross-env NODE_ENV=test NODE_OPTIONS=--experimental-vm-modules jest",
    "test:seed": "cross-env NODE_ENV=test npx tsx scripts/migrate-to-postgres.ts",
    "test:e2e:api": "cross-env NODE_ENV=test NODE_OPTIONS=--experimental-vm-modules npm run test:seed && cross-env NODE_OPTIONS=--experimental-vm-modules jest --runInBand tests/e2e/api",
    "test:e2e:browser": "cross-env NODE_ENV=test npm run test:seed && playwright test tests/e2e/browser",
    "test:release": "npm run lint && npm run typecheck && npm test && npm run test:e2e:api && npm run test:e2e:browser",
    "typecheck": "tsc --noEmit",
    "check-env": "node check-production-env.js",
    "db:sanitize": "npx tsx scripts/sanitize-db.ts",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "clean": "rm -rf dist .next",
    "lint": "npm run typecheck",
    "start:prod": "cross-env NODE_ENV=production tsx server.ts",
    "cap:init": "cap init",
    "cap:sync": "cap sync",
    "cap:add-android": "cap add android",
    "cap:add-ios": "cap add ios",
    "cap:open-android": "cap open android",
    "cap:open-ios": "cap open ios",
    "worker": "tsx server/workers/outbox.worker.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1075.0",
    "@aws-sdk/lib-storage": "^3.1075.0",
