<?xml version="1.0" encoding="utf-8"?>
<!-- DEBUG ONLY — allows cleartext (HTTP) so the app can reach a local/dev
     backend on the LAN (e.g. http://192.168.x.x:3001). NEVER ship this build. -->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
