{
  "version": 2,
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/aswaq-icon(.*)\\.png",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=2592000, stale-while-revalidate=86400"
        }
      ]
    },
    {
      "source": "/manifest.json",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, stale-while-revalidate=600"
        }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache"
        }
      ]
    }
  ],
  "rewrites": [
    { "source": "/__/auth/(.*)", "destination": "https://aswaq-48f3f.firebaseapp.com/__/auth/$1" },
    { "source": "/api/(.*)", "destination": "https://api.aswaq22.com/api/$1" },
    { "source": "/uploads/(.*)", "destination": "https://api.aswaq22.com/uploads/$1" },
    { "source": "/sitemap.xml", "destination": "https://api.aswaq22.com/sitemap.xml" },
    { "source": "/sitemaps/:file", "destination": "https://api.aswaq22.com/sitemaps/:file" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
