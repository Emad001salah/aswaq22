{
  "version": 2,
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)\\.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)\\.css",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/aswaq-icon(.*)\\.png",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=2592000, stale-while-revalidate=86400"
        }
      ]
    },
    {
      "source": "/manifest.json",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, stale-while-revalidate=600"
        }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache"
        }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "https://api.aswaq22.com/api/$1" },
    { "source": "/uploads/(.*)", "destination": "https://api.aswaq22.com/uploads/$1" },
    { "source": "/sitemap.xml", "destination": "https://api.aswaq22.com/sitemap.xml" },
    { "source": "/sitemaps/:file", "destination": "https://api.aswaq22.com/sitemaps/:file" },
    { "source": "/search/:query", "destination": "https://api.aswaq22.com/search/:query" },
    { "source": "/:country([a-zA-Z]{2})/:category/:slugAndId", "destination": "https://api.aswaq22.com/:country/:category/:slugAndId" },
    { "source": "/:country([a-zA-Z]{2})/:category", "destination": "https://api.aswaq22.com/:country/:category" },
    { "source": "/:country([a-zA-Z]{2})/:city/:category", "destination": "https://api.aswaq22.com/:country/:city/:category" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
